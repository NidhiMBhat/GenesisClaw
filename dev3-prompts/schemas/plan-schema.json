{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["architecture", "timeline", "roles", "deployment"],
  "properties": {
    "architecture": {
      "type": "array",
      "description": "5-layer system architecture",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["layer", "name", "description", "tech_stack"],
        "properties": {
          "layer": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "tech_stack": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "timeline": {
      "type": "array",
      "description": "24-hour critical path",
      "items": {
        "type": "object",
        "required": ["hour_range", "task", "owner", "deliverable"],
        "properties": {
          "hour_range": { "type": "string" },
          "task": { "type": "string" },
          "owner": { "type": "string" },
          "deliverable": { "type": "string" }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["role_title", "responsibilities", "required_skills"],
        "properties": {
          "role_title": { "type": "string" },
          "responsibilities": { "type": "array", "items": { "type": "string" } },
          "required_skills": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "deployment": {
      "type": "object",
      "required": ["recommended_models", "on_device_compatible", "constraints"],
      "properties": {
        "recommended_models": { "type": "array", "items": { "type": "string" } },
        "on_device_compatible": { "type": "boolean" },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}